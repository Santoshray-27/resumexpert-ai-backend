# ResumeXpert AI - Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB Atlas URI: mongodb+srv://<username>:<password>@cluster.mongodb.net/resumexpert
MONGODB_URI=mongodb://localhost:27017/resumexpert

# Security
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# AI API Keys
# Get Gemini API Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Fallback AI Keys
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Job Search (RapidAPI - JSearch)
RAPIDAPI_KEY=your_rapidapi_key_here

# Deployment
FRONTEND_URL=http://localhost:5173
